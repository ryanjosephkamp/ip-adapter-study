# =============================================================================
# HW13 .gitignore — Multi-Modal Generative AI Project
# =============================================================================

# -----------------------------------------------------------------------------
# Zero-Image Policy — Exclude all image formats
# -----------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.tif
*.svg
*.webp
*.ico

# -----------------------------------------------------------------------------
# Audio output files — Generated WAV/MP3 artifacts
# -----------------------------------------------------------------------------
*.wav
*.mp3
*.flac
*.ogg
*.m4a

# -----------------------------------------------------------------------------
# Hidden / planning directories
# -----------------------------------------------------------------------------
.ai/
.vscode/
.venv/
.env/
.idea/

# -----------------------------------------------------------------------------
# macOS system artifacts
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Python artifacts
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
*.so

# -----------------------------------------------------------------------------
# Jupyter / notebook artifacts
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Model weights and large binary artifacts
# -----------------------------------------------------------------------------
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.h5
*.hdf5
*.onnx

# -----------------------------------------------------------------------------
# Archive artifacts (downloaded Colab results already extracted)
# -----------------------------------------------------------------------------
*.zip
*.tar.gz
*.tar
*.gz
*.rar
*.7z

# -----------------------------------------------------------------------------
# LaTeX build artifacts
# -----------------------------------------------------------------------------
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.synctex.gz
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb

# -----------------------------------------------------------------------------
# Miscellaneous temporary files
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.swp
*.swo
*~
.cache/
.huggingface/
Thumbs.db

# -----------------------------------------------------------------------------
# PDF files (compiled reports are regenerable; source .tex is tracked)
# -----------------------------------------------------------------------------
*.pdf
